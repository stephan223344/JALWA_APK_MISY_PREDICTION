{
  "expo": {
    "name": "gowinns",
    "slug": "gowinns",
    "version": "3.0.1",
    "orientation": "portrait",
    "icon": "./assets/images/jai.png",
    "scheme": "wingoapp",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": true
    },
    "android": {
      "icon":"./assets/images/jai.png",
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false,
      "package": "com.stephanckaert.Gowinns"
    },
    "web": {
      "output": "static",
      "favicon": "./assets/images/jai.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/jai.png",
          "imageWidth": 200,
          "resizeMode": "contain",
          "backgroundColor": "#ffffff",
          "dark": {
            "backgroundColor": "#ffffff"
          }
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "3946ce94-55d0-414c-9151-02e31da6f7a9"
      }
    },
    "owner": "stephanckaerts-organization"
  }
}
